# Copy to .env.production on your VPS and fill in real values
# NEVER commit .env.production to git

NEXT_PUBLIC_SITE_URL=https://devopsguru.am
NEXT_PUBLIC_APP_NAME=DevOpsGuru
NODE_ENV=production

# Database — host = container name on Docker internal network
POSTGRES_USER=devopsguru
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=devopsguru_db
DATABASE_URL=postgresql://devopsguru:CHANGE_ME_strong_password_here@devopsguru-postgres:5432/devopsguru_db

# Redis — host = container name
REDIS_URL=redis://devopsguru-redis:6379

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# Admin login
ADMIN_EMAIL=sarmen@devopsguru.am

# Resend (https://resend.com)
RESEND_API_KEY=re_your_real_api_key
RESEND_FROM_EMAIL=noreply@devopsguru.am

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=devopsguru_uploads

# App internal URL (used by admin container to call the main app for cert issuance)
APP_INTERNAL_URL=http://devopsguru-app:3000
